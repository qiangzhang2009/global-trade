{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "build_data.js", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/favorites/(.+)", "dest": "/api/favorites.js" },
    { "src": "/api/heat/(.+)", "dest": "/api/heat.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
