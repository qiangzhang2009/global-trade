{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/heat/(.*)$",
      "dest": "/api/heat.js"
    },
    {
      "src": "/api/auth/(.*)$",
      "dest": "/api/auth.js"
    },
    {
      "src": "/api/tracking",
      "dest": "/api/tracking.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
